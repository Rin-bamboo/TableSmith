<Controls:MetroWindow x:Class="TableSmith.Views.SchemaManagement"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      Title="TableSmith: スキーマ管理"
                      Icon="pack://application:,,,/Resources/Images/TableSmith.ico"
                      Height="560"
                      Width="760"
                      MinHeight="460"
                      MinWidth="620"
                      WindowStartupLocation="CenterOwner"
                      GlowBrush="DeepSkyBlue"
                      BorderThickness="1"
                      Background="#F7F9FC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock Text="既定スキーマ"
                       VerticalAlignment="Center"
                       FontWeight="Bold" />
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding Schemas}"
                      DisplayMemberPath="SchemaName"
                      SelectedValuePath="SchemaName"
                      SelectedValue="{Binding DefaultSchemaName, UpdateSourceTrigger=PropertyChanged}"
                      Height="30"
                      Margin="0,0,16,0"
                      ToolTip="新規テーブルと、スキーマ未設定のテーブルに適用するスキーマです。" />
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="追加" Width="90" Margin="0,0,8,0" Click="AddButton_Click" />
                <Button Content="削除" Width="90" Click="RemoveButton_Click" />
            </StackPanel>
        </Grid>

        <DataGrid Grid.Row="1"
                  Margin="0,14,0,0"
                  ItemsSource="{Binding Schemas}"
                  SelectedItem="{Binding SelectedSchema}"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="#EEF4FB"
                  SelectionMode="Single"
                  SelectionUnit="FullRow">
            <DataGrid.Columns>
                <DataGridTextColumn Header="スキーマ名"
                                    Binding="{Binding SchemaName, UpdateSourceTrigger=PropertyChanged}"
                                    Width="230" />
                <DataGridTextColumn Header="説明"
                                    Binding="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="キャンセル" Width="100" Margin="0,0,8,0" Click="CancelButton_Click" />
            <Button Content="確定" Width="100" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Controls:MetroWindow>
