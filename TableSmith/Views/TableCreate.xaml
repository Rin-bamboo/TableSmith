<Window x:Class="TableSmith.Views.TableCreate"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
       xmlns:local="clr-namespace:TableSmith.ViewModels"
       mc:Ignorable="d"
       Title="TableSmith:テーブル設計支援アプリケーション" Height="401" Width="800">
    <DockPanel>

        <!-- メニューバー -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル">
                <MenuItem Header="新規" />
                <MenuItem Header="開く" />
                <MenuItem Header="終了" />
            </MenuItem>
            <MenuItem Header="ヘルプ">
                <MenuItem Header="バージョン情報" />
            </MenuItem>
        </Menu>

        <!-- メイン画面のレイアウト -->
        <Grid Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="79*"/>
                <ColumnDefinition Width="271*"/>
            </Grid.ColumnDefinitions>

            <Label Grid.Column="0" VerticalAlignment="Center" Content="テーブル情報：" Margin="5,0,5,0" Height="26"/>

            <StackPanel Grid.Column="1"  Grid.Row="0"  Margin="20,20,20,20" Grid.ColumnSpan="2">

                <Label Content="テーブル物理名" Margin="5,0,0,5" />
                <TextBox Text="{Binding CurrentTable.TableName}" />
                <!--PlaceholderText="テーブル物理名" />-->
                <Label Content="テーブル物理名" Margin="5,0,0,5" />
                <TextBox Text="{Binding CurrentTable.TableDisplayName}" />
                <!--PlaceholderText="テーブル論理名" />-->

            </StackPanel>

            <Label Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Content="カラム情報" Margin="5,0,5,0" Height="26"/>

            <DataGrid Grid.Column="1" Grid.Row="1" Margin="20,20,20,20" ItemsSource="{Binding CurrentTable.Columns}" AutoGenerateColumns="False" CanUserAddRows="True" Grid.ColumnSpan="2">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="物理名" Binding="{Binding ColumnName}" />
                    <DataGridTextColumn Header="論理名" Binding="{Binding ColumnDisplayName}" />
                    <DataGridTextColumn Header="型" Binding="{Binding DataType}" />
                    <DataGridTextColumn Header="サイズ" Binding="{Binding DataSize}" />
                    <DataGridCheckBoxColumn Header="PK" Binding="{Binding IsPrimaryKey}" />
                    <DataGridCheckBoxColumn Header="Not Null" Binding="{Binding IsNotNull}" />
                    <DataGridTextColumn Header="説明" Binding="{Binding Description}" />
                </DataGrid.Columns>

            </DataGrid>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,5" Grid.Column="2">
                <Button Content="追加" Width="75" Command="{Binding AddColumnCommand}" Margin="5"/>
                <Button Content="削除" Width="75" Command="{Binding RemoveColumnCommand}" Margin="5" />
            </StackPanel>
            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,5,0,5" Grid.Column="0" Width="170">
                <Button Content="保存" Width="75" Margin="5" Command="{Binding SaveCommand}" />
                <Button Content="読み込み" Width="75" Margin="5" Command="{Binding LoadCommand}" />
            </StackPanel>

        </Grid>

    </DockPanel>


</Window>
