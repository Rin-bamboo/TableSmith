<Controls:MetroWindow x:Class="TableSmith.Views.VersionInfo"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      Title="TableSmith: バージョン情報"
                      Icon="pack://application:,,,/Resources/Images/TableSmith.ico"
                      Height="560"
                      Width="620"
                      ResizeMode="NoResize"
                      WindowStartupLocation="CenterOwner"
                      GlowBrush="DeepSkyBlue"
                      BorderThickness="1"
                      Background="#F7F9FC">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="{Binding ProductName}"
                       FontSize="26"
                       FontWeight="Bold"
                       Foreground="#1F4E78" />
            <TextBlock Text="{Binding VersionText}"
                       FontSize="14"
                       Margin="0,4,0,0"
                       Foreground="#445566" />
        </StackPanel>

        <TextBlock Grid.Row="1"
                   Text="{Binding Description}"
                   TextWrapping="Wrap"
                   Margin="0,18,0,18"
                   FontSize="14" />

        <Border Grid.Row="2"
                Padding="14"
                Background="White"
                BorderBrush="#C7D3DF"
                BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="130" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Text="アセンブリ" FontWeight="Bold" Margin="0,0,10,10" />
                <TextBlock Grid.Column="1" Text="{Binding AssemblyName}" Margin="0,0,0,10" />

                <TextBlock Grid.Row="1" Text="実行環境" FontWeight="Bold" Margin="0,0,10,10" />
                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding RuntimeText}" Margin="0,0,0,10" />

                <TextBlock Grid.Row="2" Text="ライセンス" FontWeight="Bold" Margin="0,0,10,10" />
                <TextBlock Grid.Row="2" Grid.Column="1" Text="MIT License" Margin="0,0,0,10" />

                <TextBlock Grid.Row="3" Text="著作権" FontWeight="Bold" Margin="0,0,10,0" />
                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding Copyright}" />
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Margin="0,14,0,0"
                Padding="12"
                Background="#EEF4FB"
                BorderBrush="#B7CCE2"
                BorderThickness="1">
            <StackPanel>
                <TextBlock x:Name="UpdateStatusTextBlock"
                           Text="GitHub Releasesから最新バージョンを確認できます。"
                           TextWrapping="Wrap" />
                <ProgressBar x:Name="UpdateProgressBar"
                             Height="16"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             Visibility="Collapsed"
                             Margin="0,10,0,0" />
            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,18,0,0">
            <Button x:Name="CheckUpdateButton"
                    Content="更新を確認"
                    Width="110"
                    Margin="0,0,8,0"
                    Click="CheckUpdateButton_Click" />
            <Button x:Name="UpdateNowButton"
                    Content="今すぐ更新"
                    Width="110"
                    Margin="0,0,8,0"
                    Visibility="Collapsed"
                    Click="UpdateNowButton_Click" />
            <Button x:Name="CloseButton"
                    Content="閉じる"
                    Width="100"
                    Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Controls:MetroWindow>
