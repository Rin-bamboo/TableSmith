<Controls:MetroWindow x:Class="TableSmith.Views.IndexDefinitionEdit"
                      x:Name="RootWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      Title="TableSmith: インデックス定義"
                      Icon="pack://application:,,,/Resources/Images/TableSmith.ico"
                      Height="720"
                      Width="980"
                      MinHeight="540"
                      MinWidth="820"
                      WindowStartupLocation="CenterOwner"
                      GlowBrush="DeepSkyBlue"
                      BorderThickness="1"
                      Background="#F7F9FC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="220" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <GroupBox Header="インデックス一覧" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                    <Button Content="追加" Width="90" Margin="0,0,8,0" Click="AddIndexButton_Click" />
                    <Button Content="削除" Width="90" Click="RemoveIndexButton_Click" />
                </StackPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding Indexes}"
                          SelectedItem="{Binding SelectedIndex}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowHeaderWidth="0"
                          SelectionMode="Single"
                          SelectionUnit="FullRow"
                          AlternatingRowBackground="#EEF4FB">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="インデックス名"
                                            Binding="{Binding IndexName}"
                                            Width="260"
                                            IsReadOnly="True" />
                        <DataGridCheckBoxColumn Header="Unique"
                                               Binding="{Binding IsUnique}"
                                               Width="85"
                                               IsReadOnly="True" />
                        <DataGridCheckBoxColumn Header="Clustered"
                                               Binding="{Binding IsClustered}"
                                               Width="95"
                                               IsReadOnly="True" />
                        <DataGridTextColumn Header="説明"
                                            Binding="{Binding Description}"
                                            Width="*"
                                            IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="1" Header="インデックス設定" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="110" />
                    <ColumnDefinition Width="110" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="インデックス名" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBox Grid.Column="1"
                         Text="{Binding SelectedIndex.IndexName, UpdateSourceTrigger=PropertyChanged}"
                         IsEnabled="{Binding SelectedIndex.IsNameCustomized}"
                         Height="30"
                         Margin="0,0,16,8"
                         ToolTip="標準名は IX_テーブル名_カラム名 です。カスタム名を有効にすると任意の名前を入力できます。" />
                <CheckBox Grid.Column="2"
                          Content="カスタム名"
                          IsChecked="{Binding SelectedIndex.IsNameCustomized, UpdateSourceTrigger=PropertyChanged}"
                          VerticalAlignment="Center"
                          Margin="0,0,12,8"
                          Checked="CustomNameCheckBox_Changed"
                          Unchecked="CustomNameCheckBox_Changed" />
                <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,8">
                    <CheckBox Content="Unique"
                              IsChecked="{Binding SelectedIndex.IsUnique, UpdateSourceTrigger=PropertyChanged}"
                              Margin="0,0,12,0" />
                    <CheckBox Content="Clustered"
                              IsChecked="{Binding SelectedIndex.IsClustered, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>

                <TextBlock Grid.Row="1" Text="説明" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         Grid.ColumnSpan="3"
                         Text="{Binding SelectedIndex.Description, UpdateSourceTrigger=PropertyChanged}"
                         Height="30" />
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="対象カラム" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,8">
                    <Button Content="追加" Width="90" Margin="0,0,8,0" Click="AddIndexColumnButton_Click" />
                    <Button Content="削除" Width="90" Click="RemoveIndexColumnButton_Click" />
                </StackPanel>
                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SelectedIndex.Columns}"
                          SelectedItem="{Binding SelectedIndexColumn}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          RowHeaderWidth="0"
                          AlternatingRowBackground="#EEF4FB">
                    <DataGrid.Columns>
                        <DataGridComboBoxColumn x:Name="IndexColumnNameColumn"
                                                Header="カラム名"
                                                SelectedItemBinding="{Binding ColumnName, UpdateSourceTrigger=PropertyChanged}"
                                                Width="*" />
                        <DataGridCheckBoxColumn Header="降順"
                                               Binding="{Binding IsDescending, UpdateSourceTrigger=PropertyChanged}"
                                               Width="100" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="キャンセル" Width="100" Margin="0,0,8,0" Click="CancelButton_Click" />
            <Button Content="確定" Width="100" Click="SaveButton_Click" />
        </StackPanel>
    </Grid>
</Controls:MetroWindow>
