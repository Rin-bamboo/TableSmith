<Controls:MetroWindow x:Class="TableSmith.Views.OperationGuide"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      Title="TableSmith: 操作説明"
                      Icon="pack://application:,,,/Resources/Images/TableSmith.ico"
                      Height="680"
                      Width="980"
                      MinHeight="540"
                      MinWidth="800"
                      WindowStartupLocation="CenterOwner"
                      GlowBrush="DeepSkyBlue"
                      BorderThickness="1"
                      Background="#F7F9FC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="White"
                BorderBrush="#C7D3DF"
                BorderThickness="1"
                Padding="8">
            <ListBox ItemsSource="{Binding Topics}"
                     SelectedItem="{Binding SelectedTopic}"
                     DisplayMemberPath="Title"
                     BorderThickness="0"
                     FontSize="14"
                     Padding="0" />
        </Border>

        <Border Grid.Column="2"
                Background="White"
                BorderBrush="#C7D3DF"
                BorderThickness="1">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          Padding="24">
                <StackPanel>
                    <TextBlock Text="{Binding SelectedTopic.Title}"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="#1F4E78"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding SelectedTopic.Overview}"
                               FontSize="14"
                               TextWrapping="Wrap"
                               LineHeight="22"
                               Margin="0,10,0,18" />

                    <Border Background="#EEF4FB"
                            BorderBrush="#B7CCE2"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="事前確認"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{Binding SelectedTopic.Prerequisite}"
                                       TextWrapping="Wrap"
                                       LineHeight="21" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="操作手順"
                               FontSize="17"
                               FontWeight="Bold"
                               Margin="0,0,0,8" />
                    <ItemsControl ItemsSource="{Binding SelectedTopic.Steps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="32" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="22"
                                            Height="22"
                                            Background="#4472C4"
                                            CornerRadius="3"
                                            VerticalAlignment="Top">
                                        <TextBlock Text="{Binding Number}"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Text}"
                                               TextWrapping="Wrap"
                                               LineHeight="21"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <StackPanel Margin="0,18,0,0">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SelectedTopic.HasItems}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>

                        <TextBlock Text="項目説明"
                                   FontSize="17"
                                   FontWeight="Bold"
                                   Margin="0,0,0,8" />
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="#4472C4" Padding="8">
                                <TextBlock Text="項目名" Foreground="White" FontWeight="Bold" />
                            </Border>
                            <Border Grid.Column="1" Background="#4472C4" Padding="8">
                                <TextBlock Text="入力内容" Foreground="White" FontWeight="Bold" />
                            </Border>
                            <Border Grid.Column="2" Background="#4472C4" Padding="8">
                                <TextBlock Text="補足" Foreground="White" FontWeight="Bold" />
                            </Border>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding SelectedTopic.Items}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border BorderBrush="#D6DEE6" BorderThickness="1,0,1,1" Padding="8">
                                            <TextBlock Text="{Binding Name}"
                                                       FontWeight="Bold"
                                                       TextWrapping="Wrap" />
                                        </Border>
                                        <Border Grid.Column="1"
                                                BorderBrush="#D6DEE6"
                                                BorderThickness="0,0,1,1"
                                                Padding="8">
                                            <TextBlock Text="{Binding Input}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="20" />
                                        </Border>
                                        <Border Grid.Column="2"
                                                BorderBrush="#D6DEE6"
                                                BorderThickness="0,0,1,1"
                                                Padding="8">
                                            <TextBlock Text="{Binding Detail}"
                                                       TextWrapping="Wrap"
                                                       LineHeight="20" />
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <Border Background="#FFF8E6"
                            BorderBrush="#E2C879"
                            BorderThickness="1"
                            Padding="14"
                            Margin="0,18,0,0">
                        <StackPanel>
                            <TextBlock Text="注意点"
                                       FontWeight="Bold"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="{Binding SelectedTopic.Note}"
                                       TextWrapping="Wrap"
                                       LineHeight="21" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Button Grid.Row="1"
                Grid.ColumnSpan="3"
                Content="閉じる"
                Width="100"
                HorizontalAlignment="Right"
                Margin="0,14,0,0"
                Click="CloseButton_Click" />
    </Grid>
</Controls:MetroWindow>
