<Controls:MetroWindow x:Class="TableSmith.Views.IndexManagement"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      Title="TableSmith: インデックス管理"
                      Icon="pack://application:,,,/Resources/Images/TableSmith.ico"
                      Height="650"
                      Width="1000"
                      MinHeight="520"
                      MinWidth="820"
                      WindowStartupLocation="CenterOwner"
                      GlowBrush="DeepSkyBlue"
                      BorderThickness="1"
                      Background="#F7F9FC">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="340" />
            <ColumnDefinition Width="14" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <GroupBox Header="対象テーブル" Padding="12">
            <DataGrid ItemsSource="{Binding Tables}"
                      SelectedItem="{Binding SelectedTable}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      RowHeaderWidth="0"
                      AlternatingRowBackground="#EEF4FB"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="スキーマ"
                                        Binding="{Binding SchemaName}"
                                        Width="100"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="テーブル物理名"
                                        Binding="{Binding TableName}"
                                        Width="*"
                                        IsReadOnly="True" />
                    <DataGridTextColumn Header="論理名"
                                        Binding="{Binding TableDisplayName}"
                                        Width="*"
                                        IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <GroupBox Grid.Column="2" Header="インデックス一覧" Padding="12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,10">
                    <Button Content="定義を編集"
                            Width="110"
                            Click="EditButton_Click"
                            ToolTip="選択中テーブルのインデックス追加・削除・カラム設定を編集します。" />
                </StackPanel>

                <DataGrid Grid.Row="1"
                          ItemsSource="{Binding SelectedTable.Indexes}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          RowHeaderWidth="0"
                          AlternatingRowBackground="#EEF4FB">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="インデックス名"
                                            Binding="{Binding IndexName}"
                                            Width="210"
                                            IsReadOnly="True" />
                        <DataGridCheckBoxColumn Header="Unique"
                                               Binding="{Binding IsUnique}"
                                               Width="75"
                                               IsReadOnly="True" />
                        <DataGridCheckBoxColumn Header="Clustered"
                                               Binding="{Binding IsClustered}"
                                               Width="85"
                                               IsReadOnly="True" />
                        <DataGridTemplateColumn Header="対象カラム" Width="190">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <ItemsControl ItemsSource="{Binding Columns}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#E6EEF6"
                                                        BorderBrush="#B8CADB"
                                                        BorderThickness="1"
                                                        Padding="5,2"
                                                        Margin="0,0,4,2">
                                                    <TextBlock>
                                                        <Run Text="{Binding ColumnName}" />
                                                        <Run Text=" " />
                                                        <Run Text="{Binding SortDirection, Mode=OneWay}" />
                                                    </TextBlock>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="説明"
                                            Binding="{Binding Description}"
                                            Width="*"
                                            IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </GroupBox>

        <StackPanel Grid.Row="1"
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,14,0,0">
            <Button Content="閉じる" Width="100" Click="CloseButton_Click" />
        </StackPanel>
    </Grid>
</Controls:MetroWindow>
