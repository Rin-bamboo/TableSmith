<Controls:MetroWindow x:Class="TableSmith.Views.MainWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:TableSmith.ViewModels"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      mc:Ignorable="d"
                      Title="TableSmith:テーブル設計支援アプリケーション"
                      Height="450" Width="800"
                      WindowStartupLocation="CenterScreen"
                      GlowBrush="DeepSkyBlue"
                      BorderThickness="1"
                      ShowTitleBar="True"
                      ShowIconOnTitleBar="True"
                      Background="White">

    <DockPanel>

        <!-- メニューバー -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル">
                <MenuItem Header="新規" />
                <MenuItem Header="開く" />
                <MenuItem Header="終了" />
            </MenuItem>
            <MenuItem Header="ヘルプ">
                <MenuItem Header="バージョン情報" />
            </MenuItem>
        </Menu>

        <!-- ボタンエリア -->
        <WrapPanel Margin="5" Orientation="Horizontal" ItemHeight="150" ItemWidth="150"  >

            <Button x:Name="ButtonTableCreate" Margin="5" Background="lightgray" Click="ButtonTableCreate_Click">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Images/NewCreate.png" Width="50" Height="50" Margin="0,5"/>
                    <Label Content="テーブル定義作成" HorizontalAlignment="Center" Background="Transparent" BorderBrush="Transparent" />
                </StackPanel>
            </Button>

            <Button x:Name="ButtonTableList" Margin="5" Background="darkgray" Click="ButtonTableList_Click" >
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Images/List.png" Width="32" Height="32" Margin="0,5"/>
                    <Label Content="テーブル一覧" HorizontalAlignment="Center"  Background="Transparent" BorderBrush="Transparent"/>
                </StackPanel>

            </Button>

        </WrapPanel>
    </DockPanel>
</Controls:MetroWindow>
