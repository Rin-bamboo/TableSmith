<Controls:MetroWindow x:Class="TableSmith.Views.MainWindow"
                      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                      xmlns:local="clr-namespace:TableSmith.ViewModels"
                      xmlns:Controls="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
                      mc:Ignorable="d"
                      Title="TableSmith:テーブル設計支援アプリケーション"
                      Height="450" Width="800"
                      WindowStartupLocation="CenterScreen"
                      GlowBrush="DeepSkyBlue"
                      BorderThickness="1"
                      ShowTitleBar="True"
                      ShowIconOnTitleBar="True"
                      Background="White">

    <DockPanel>

        <!-- メニューバー -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="ファイル">
                <MenuItem Header="新規" Click="NewMenuItem_Click" />
                <MenuItem Header="開く" Click="OpenMenuItem_Click" />
                <Separator />
                <MenuItem Header="保存" Click="SaveMenuItem_Click" />
                <MenuItem Header="名前を付けて保存" Click="SaveAsMenuItem_Click" />
                <Separator />
                <MenuItem Header="終了" Click="ExitMenuItem_Click" />
            </MenuItem>
            <MenuItem Header="ヘルプ">
                <MenuItem Header="バージョン情報" Click="VersionInfoMenuItem_Click" />
            </MenuItem>
        </Menu>

        <Border DockPanel.Dock="Top" Margin="10,10,10,5" Padding="12" Background="#EEF4FB" BorderBrush="#B7CCE2" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="プロジェクト名" VerticalAlignment="Center" FontWeight="Bold" />
                <TextBox Grid.Column="1"
                         Text="{Binding ProjectName, UpdateSourceTrigger=PropertyChanged}"
                         Height="30"
                         MaxLength="100"
                         ToolTip="テーブル設計を管理するプロジェクト名を入力してください。JSON保存やテーブル定義書に使用されます。" />
            </Grid>
        </Border>

        <!-- ボタンエリア -->
        <WrapPanel Margin="5" Orientation="Horizontal" ItemHeight="150" ItemWidth="150"  >

            <Button x:Name="ButtonTableCreate" Margin="5" Background="lightgray" Click="ButtonTableCreate_Click">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Images/NewCreate.png" Width="50" Height="50" Margin="0,5"/>
                    <Label Content="テーブル定義作成" HorizontalAlignment="Center" Background="Transparent" BorderBrush="Transparent" />
                </StackPanel>
            </Button>

            <Button x:Name="ButtonTableList" Margin="5" Background="darkgray" Click="ButtonTableList_Click" >
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Images/List.png" Width="32" Height="32" Margin="0,5"/>
                    <Label Content="テーブル一覧" HorizontalAlignment="Center"  Background="Transparent" BorderBrush="Transparent"/>
                </StackPanel>
            </Button>

            <Button x:Name="ButtonDefinitionExport" Margin="5" Background="#D8E8F5" Click="ButtonDefinitionExport_Click">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Images/List.png" Width="38" Height="38" Margin="0,5"/>
                    <Label Content="定義書出力" HorizontalAlignment="Center" Background="Transparent" BorderBrush="Transparent" />
                </StackPanel>
            </Button>

            <Button x:Name="ButtonErDiagram" Margin="5" Background="#DCEBDD" Click="ButtonErDiagram_Click">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Images/NewCreate.png" Width="42" Height="42" Margin="0,5"/>
                    <Label Content="ER図" HorizontalAlignment="Center" Background="Transparent" BorderBrush="Transparent" />
                </StackPanel>
            </Button>

            <Button x:Name="ButtonCreateSql" Margin="5" Background="#E8E2F3" Click="ButtonCreateSql_Click">
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center">
                    <Image Source="pack://application:,,,/Resources/Images/NewCreate.png" Width="42" Height="42" Margin="0,5"/>
                    <Label Content="CREATE文" HorizontalAlignment="Center" Background="Transparent" BorderBrush="Transparent" />
                </StackPanel>
            </Button>
        </WrapPanel>
    </DockPanel>
</Controls:MetroWindow>
